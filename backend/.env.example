# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure Email Communication Services
AZURE_EMAIL_CONNECTION_STRING=endpoint=https://your-resource.communication.azure.com/;accesskey=xxx
AZURE_EMAIL_SENDER=DoNotReply@yourdomain.azurecomm.net

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/assessment_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=assessment_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password_here

# Application Settings
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change-this-to-a-long-random-secret-in-production
TEMP_PASSWORD_LENGTH=8

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000
